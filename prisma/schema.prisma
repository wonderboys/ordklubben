generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  DRAFT
  APPROVED
  REJECTED
  ARCHIVED
}

enum PartOfSpeech {
  SUBSTANTIV
  VERB
  ADJEKTIV
  ADVERB
  PRONOMEN
  RAKNEORD
  INTERJEKTION
  FORKORTNING
  OVRIGT
}

enum LexicalEntryType {
  DEFINITION
  SYNONYM
  ANTONYM
  EXPRESSION
  RELATED
}

enum HintType {
  DEFINITION
  PARAPHRASE
  ASSOCIATION
  SYNONYM
  WORDPLAY
  EXAMPLE
  THEME
  OTHER
}

enum MediaType {
  IMAGE
  AUDIO
  VIDEO
}

enum ImportBatchStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ImportBatchType {
  WORDS
  HINTS
  WORDS_AND_HINTS
  LEXICON
}

enum HintCandidateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PuzzleType {
  WORD_GRID
  DAILY_WORD
  STEPWISE
  CROSSWORD
}

enum PuzzleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum PuzzleDirection {
  ACROSS
  DOWN
}

enum GrammaticalGender {
  EN
  ETT
}

enum WordRelationType {
  SYNONYM
  ANTONYM
  RELATED
  COMPOSED_OF
  PART_OF
}

enum GameStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum EditionStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum EditionType {
  DAILY
  WEEKLY
  FEATURED
  TEST
  STATIC
}

enum GameEditionWordRole {
  SOLUTION
  SEED
  START
  TARGET
  STEP
  ENTRY
}

model Word {
  id                   String                 @id @default(cuid())
  answer               String
  normalizedAnswer     String                 @unique
  length               Int
  language             String                 @default("sv")
  status               ContentStatus          @default(DRAFT)
  source               String                 @default("manual")
  sourceReference      String?
  difficulty           Int?
  frequency            Int?
  crosswordScore       Int?
  notes                String?                @db.Text
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  hints                Hint[]
  hintCandidates       HintCandidate[]
  themes               WordTheme[]
  puzzleEntries        PuzzleEntry[]
  lexicalEntries       WordLexicalEntry[]
  linkedLexicalEntries WordLexicalEntry[]     @relation("LexicalLinkedWord")
  rebusEntries         RebusEntry[]
  mediaAssets          MediaAsset[]
  languageData         WordLanguageData?
  outgoingRelations    WordRelation[]         @relation("WordRelationSource")
  incomingRelations    WordRelation[]         @relation("WordRelationTarget")
  sourceRecords        WordSourceRecord[]
  editorialOverride    WordEditorialOverride?
  gameWords            GameWord[]
  gameEditionWords     GameEditionWord[]
  importRows           ImportBatchRow[]

  @@index([answer])
  @@index([status])
  @@index([source])
}

model WordSourceRecord {
  id              String       @id @default(cuid())
  wordId          String
  word            Word         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  importBatchId   String?
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  sourceKey       String
  sourceReference String?
  rawValue        String?
  normalizedValue String
  observedAnswer  String?
  rank            Int?
  frequency       Int?
  cefr            String?
  metadata        Json?
  isExcluded      Boolean      @default(false)
  firstImportedAt DateTime     @default(now())
  lastImportedAt  DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([wordId, sourceKey, sourceReference])
  @@index([wordId])
  @@index([importBatchId])
  @@index([sourceKey])
}

model WordEditorialOverride {
  id             String         @id @default(cuid())
  wordId         String         @unique
  word           Word           @relation(fields: [wordId], references: [id], onDelete: Cascade)
  answer         String?
  status         ContentStatus?
  difficulty     Int?
  frequency      Int?
  crosswordScore Int?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

/// Lexical data describes meaning and relations — not playable hints.
/// `linkedWordId` prepares future links to other Word rows (e.g. synonym → GÅNGART).
model WordLexicalEntry {
  id              String           @id @default(cuid())
  wordId          String
  word            Word             @relation(fields: [wordId], references: [id], onDelete: Cascade)
  importBatchId   String?
  importBatch     ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  type            LexicalEntryType
  value           String
  source          String           @default("manual")
  sourceReference String?
  linkedWordId    String?
  linkedWord      Word?            @relation("LexicalLinkedWord", fields: [linkedWordId], references: [id], onDelete: SetNull)
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  importRows      ImportBatchRow[]

  @@unique([wordId, type, value])
  @@index([wordId])
  @@index([importBatchId])
  @@index([type])
  @@index([linkedWordId])
}

/// Grammatical and morphological properties of a word — not meanings or playable hints.
model WordLanguageData {
  id            String             @id @default(cuid())
  wordId        String             @unique
  word          Word               @relation(fields: [wordId], references: [id], onDelete: Cascade)
  partOfSpeech  PartOfSpeech?
  gender        GrammaticalGender?
  lemma         String?
  pronunciation String?
  /// Noun inflections and future morphological forms, e.g. definiteSingular, indefinitePlural.
  inflections   Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([partOfSpeech])
}

/// Structured links between Word rows — distinct from lexical meaning entries.
model WordRelation {
  id              String           @id @default(cuid())
  sourceWordId    String
  sourceWord      Word             @relation("WordRelationSource", fields: [sourceWordId], references: [id], onDelete: Cascade)
  targetWordId    String
  targetWord      Word             @relation("WordRelationTarget", fields: [targetWordId], references: [id], onDelete: Cascade)
  relationType    WordRelationType
  source          String           @default("manual")
  sourceReference String?
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([sourceWordId, targetWordId, relationType])
  @@index([sourceWordId])
  @@index([targetWordId])
  @@index([relationType])
}

model Game {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  status      GameStatus    @default(ACTIVE)
  description String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  words       GameWord[]
  editions    GameEdition[]
}

model GameWord {
  id            String   @id @default(cuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  wordId        String
  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  canBeGuess    Boolean  @default(false)
  canBeSolution Boolean  @default(false)
  canBeSeed     Boolean  @default(false)
  blocked       Boolean  @default(false)
  priority      Int?
  difficulty    Int?
  notes         String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([gameId, wordId])
  @@index([gameId, blocked])
  @@index([gameId, canBeGuess])
  @@index([gameId, canBeSolution])
  @@index([gameId, canBeSeed])
  @@index([wordId])
}

model GameEdition {
  id          String            @id @default(cuid())
  gameId      String
  game        Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  title       String?
  editionType EditionType
  status      EditionStatus     @default(DRAFT)
  publishAt   DateTime?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  words       GameEditionWord[]

  @@index([gameId, status])
  @@index([gameId, publishAt])
}

model GameEditionWord {
  id        String              @id @default(cuid())
  editionId String
  edition   GameEdition         @relation(fields: [editionId], references: [id], onDelete: Cascade)
  wordId    String
  word      Word                @relation(fields: [wordId], references: [id], onDelete: Restrict)
  role      GameEditionWordRole
  position  Int?
  metadata  Json?
  createdAt DateTime            @default(now())

  @@unique([editionId, wordId, role])
  @@index([editionId, role, position])
  @@index([wordId])
}

model Hint {
  id                     String          @id @default(cuid())
  wordId                 String
  word                   Word            @relation(fields: [wordId], references: [id], onDelete: Cascade)
  importBatchId          String?
  importBatch            ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  text                   String
  type                   HintType        @default(DEFINITION)
  status                 ContentStatus   @default(DRAFT)
  difficulty             Int?
  tone                   String?
  source                 String?
  notes                  String?         @db.Text
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  approvedFromCandidates HintCandidate[]
  puzzleEntries          PuzzleEntry[]
  importRows             ImportBatchRow[] @relation("ImportBatchRowHint")

  @@unique([wordId, text])
  @@index([wordId])
  @@index([importBatchId])
  @@index([status])
}

model HintCandidate {
  id             String              @id @default(cuid())
  wordId         String
  word           Word                @relation(fields: [wordId], references: [id], onDelete: Cascade)
  text           String
  type           HintType            @default(DEFINITION)
  status         HintCandidateStatus @default(PENDING)
  difficulty     Int?
  tone           String?
  source         String              @default("manual")
  model          String?
  promptVersion  String?
  notes          String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  reviewedAt     DateTime?
  approvedHintId String?
  approvedHint   Hint?               @relation(fields: [approvedHintId], references: [id], onDelete: SetNull)

  @@index([wordId])
  @@index([status])
}

model RebusEntry {
  id              String        @id @default(cuid())
  wordId          String
  word            Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)
  value           String
  difficulty      Int?
  source          String        @default("manual")
  sourceReference String?
  notes           String?       @db.Text
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([wordId, value])
  @@index([wordId])
  @@index([status])
}

model MediaAsset {
  id              String        @id @default(cuid())
  wordId          String
  word            Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)
  mediaType       MediaType
  title           String?
  altText         String?
  prompt          String?       @db.Text
  source          String        @default("manual")
  sourceReference String?
  attribution     String?
  license         String?
  notes           String?       @db.Text
  filePath        String?
  status          ContentStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([wordId])
  @@index([status])
  @@index([mediaType])
}

model Theme {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  words       WordTheme[]
}

model WordTheme {
  wordId  String
  themeId String
  word    Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)
  theme   Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([wordId, themeId])
  @@index([themeId])
}

model Puzzle {
  id           String              @id @default(cuid())
  type         PuzzleType          @default(WORD_GRID)
  title        String
  slug         String?             @unique
  status       PuzzleStatus        @default(DRAFT)
  width        Int
  height       Int
  description  String?             @db.Text
  publishDate  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  entries      PuzzleEntry[]
  blockedCells PuzzleBlockedCell[]

  @@index([status])
  @@index([type])
}

model PuzzleBlockedCell {
  id        String   @id @default(cuid())
  puzzleId  String
  puzzle    Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  row       Int
  col       Int
  createdAt DateTime @default(now())

  @@unique([puzzleId, row, col])
  @@index([puzzleId])
}

model PuzzleEntry {
  id             String          @id @default(cuid())
  puzzleId       String
  puzzle         Puzzle          @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  wordId         String
  word           Word            @relation(fields: [wordId], references: [id], onDelete: Restrict)
  hintId         String?
  hint           Hint?           @relation(fields: [hintId], references: [id], onDelete: SetNull)
  answerSnapshot String
  hintSnapshot   String?
  row            Int
  col            Int
  direction      PuzzleDirection
  number         Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([puzzleId, wordId])
  @@index([puzzleId])
  @@index([wordId])
}

model ImportBatch {
  id            String             @id @default(cuid())
  type          ImportBatchType    @default(WORDS)
  filename      String?
  source        String?
  sourceName    String?
  sourceVersion String?
  sourceLicense String?
  sourceUrl     String?
  sourceReference String?
  sourceComment String?            @db.Text
  importedAt    DateTime           @default(now())
  importedBy    String?
  status        ImportBatchStatus  @default(PENDING)
  totalRows     Int                @default(0)
  importedRows  Int                @default(0)
  skippedRows   Int                @default(0)
  errorRows     Json?
  summary       Json?
  createdAt     DateTime           @default(now())
  completedAt   DateTime?
  rows          ImportBatchRow[]
  sourceRecords WordSourceRecord[]
  hints         Hint[]
  lexicalEntries WordLexicalEntry[]
}

model ImportBatchRow {
  id             String           @id @default(cuid())
  importBatchId  String
  importBatch    ImportBatch      @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber      Int
  outcome        String
  entityType     String
  answer         String?
  hint           String?
  value          String?
  reason         String?          @db.Text
  wordId         String?
  word           Word?            @relation(fields: [wordId], references: [id], onDelete: SetNull)
  hintId         String?
  importedHint   Hint?            @relation("ImportBatchRowHint", fields: [hintId], references: [id], onDelete: SetNull)
  lexicalEntryId String?
  lexicalEntry   WordLexicalEntry? @relation(fields: [lexicalEntryId], references: [id], onDelete: SetNull)
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([importBatchId, outcome])
  @@index([importBatchId, entityType])
  @@index([wordId])
  @@index([hintId])
  @@index([lexicalEntryId])
}
